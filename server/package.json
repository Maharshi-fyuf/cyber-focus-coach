{
  "name": "cyber-focus-coach-server",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "npx tsx watch src/index.ts",
    "build": "npx tsc",
    "start": "node dist/index.js",
    "typecheck": "npx tsc --noEmit",
    "db:setup": "npx tsx scripts/setup-db.ts",
    "db:reset": "node -e \"const fs=require('fs'); fs.rmSync('data/cfc.db', {force:true});\" && npm run db:setup"
  },
  "dependencies": {
    "@cyber-focus-coach/shared": "*",
    "@libsql/client": "^0.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
