{
  "name": "cyber-focus-coach",
  "version": "1.0.0",
  "private": true,
  "description": "Cyber Focus Coach - AI-powered cyber-themed focus assistant",
  "workspaces": [
    "shared",
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -k -p \"[{name}]\" -c \"cyan.bold,yellow.bold\" \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
