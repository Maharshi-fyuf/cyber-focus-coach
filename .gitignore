# ============================================================
# Cyber Focus Coach — .gitignore
# ============================================================

# ---- Node.js ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# ---- Build outputs ----
dist/
build/
.vite/
*.tsbuildinfo

# ---- Environment / Secrets ----
.env
.env.local
.env.development
.env.production
.env.staging
*.pem
*.key

# ---- Database files ----
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-shm
*.db-wal
# Keep schema files
!schema.sql
!seed.sql

# ---- Logs ----
logs/
*.log
server.log

# ---- OS files ----
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ---- IDE / Editor ----
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---- Testing ----
coverage/
.nyc_output

# ---- TypeScript ----
*.js.map

# ---- Temporary ----
tmp/
temp/
.cache/
